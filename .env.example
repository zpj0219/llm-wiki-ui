# Hermes Gateway
# HERMES_API_KEY 必须与 hermes-data/.env 中的 API_SERVER_KEY 一致
HERMES_API_KEY=change-me-api-server-key
HERMES_GATEWAY_URL=http://localhost:8642
USE_HERMES_CHAT=auto
DEFAULT_CHAT_MODEL=hermes-agent

# 知识库
# Docker Compose 使用 HERMES_KB_PATH 将宿主机目录挂载到容器
HERMES_KB_PATH=../hermes-data/data/home/Documents/knowledge-base
# 本地直接运行 FastAPI 时可显式设置 KNOWLEDGE_BASE_ROOT
# KNOWLEDGE_BASE_ROOT=../hermes-data/data/home/Documents/knowledge-base

# SQLite
# 本地默认 backend/data/app.db；Docker Compose 固定为 /var/lib/llm-wiki-ui/app.db
# DATABASE_PATH=backend/data/app.db

# 对话结晶 Webhook
# URL 默认从 Gateway 主机推导到 8644；Secret 必须与 Hermes crystallize 路由一致
# HERMES_WEBHOOK_URL=http://localhost:8644
HERMES_WEBHOOK_SECRET=change-me-crystallize-secret
HERMES_WEBHOOK_ROUTE=crystallize

# 用户管理：local（本地账号）或 odoo（Odoo SSO）
USER_MANAGEMENT_MODE=local
# ODOO_SSO_JWT_SECRET=change-me-odoo-jwt-secret

# Docker 对外端口
APP_PORT=3000
