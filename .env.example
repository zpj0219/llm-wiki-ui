# Hermes Gateway（与 hermes-data/.env 中 API_SERVER_KEY 一致）
HERMES_API_KEY=change-me-local-dev
HERMES_GATEWAY_URL=http://localhost:8642
USE_HERMES_CHAT=auto

# OpenWebUI 连接 Hermes 时使用的逻辑模型（通常为 hermes-agent）
DEFAULT_CHAT_MODEL=hermes-agent

# 知识库路径（本地开发默认指向 hermes-data）
HERMES_KB_PATH=../hermes-data/data/home/Documents/knowledge-base

# SQLite 数据库（用户、Token、对话会话）
# DATABASE_PATH=backend/data/app.db

# Odoo JWT SSO 桥接（与 Odoo 自定义模块共享密钥，不为空即启用）
# ODOO_SSO_JWT_SECRET=

# 用户管理模式：local（管理员添加用户） | odoo（Odoo SSO 统一管理，隐藏用户管理入口）
# USER_MANAGEMENT_MODE=local
